{
  "name": "y2k-mp3-ripper",
  "version": "1.0.0",
  "description": "Y2K MP3 RIPPER - Descarga videos de YouTube como MP3",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-packager . \"Y2K MP3 Ripper\" --platform=win32 --arch=x64 --icon=icono.ico --out=release --overwrite --ignore=\"release|dist|\\.git|\\.claude\" --asar",
    "web": "node app.js"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "electron": "^41.0.3",
    "nodemon": "^3.0.1",
    "png-to-ico": "^3.0.1"
  },
  "keywords": ["youtube", "downloader", "mp3", "yt-dlp"],
