{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Y2K MP3 Ripper",
  "version": "1.0.0",
  "identifier": "com.y2k.mp3ripper",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Y2K MP3 RIPPER v1.0",
        "width": 760,
        "height": 820,
        "decorations": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
